{
  "name": "stickyinc",
  "version": "0.5.2",
  "description": "A reification layer between LLM conversations and your commitments. MCP server + floating pane.",
  "type": "module",
  "bin": {
    "stickyinc-mcp": "./dist/index.js",
    "stickyinc-watch": "./dist/watch-cli.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js dist/watch-cli.js",
    "start": "node dist/index.js",
    "watch": "tsx src/watch-cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.6.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3"]
  }
}
