{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "StickyInc",
  "version": "0.5.2",
  "identifier": "app.stickyinc.pane",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm -C .. exec tsc && pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "StickyInc",
        "width": 8,
        "height": 800,
        "x": 0,
        "y": 0,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "fullscreen": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "resources": ["../../dist/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFNjNEQzA4NkNDNEYyREUKUldUZThzUnNDTnhqdm9vYnVGWS9vV3lsenhnRGVmdzdWSS9KZnF5TkZHQm82UUtEdlM4REdmRTcK",
      "endpoints": [
        "https://github.com/Astralchemist/stickyinc/releases/latest/download/latest.json"
      ]
    }
  }
}
